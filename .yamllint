---
extends: default
rules:
  line-length:
    max: 120
  indentation:
    spaces: 2
    check-multi-line-strings: false
  comments:
    min-spaces-from-content: 1
    require-starting-space: true
  document-start: disable
  truthy:
    allowed: ['true', 'false']
    check-keys: false
  braces:
    max-spaces-inside: 0
    min-spaces-inside: 0
  brackets:
    max-spaces-inside: 0
    min-spaces-inside: 0
